{
  "type": "object",
  "description": "Database change analysis result",
  "properties": {
    "table": {
      "type": "string",
      "description": "Source database table"
    },
    "operation": {
      "type": "string",
      "enum": ["INSERT", "UPDATE", "DELETE"]
    },
    "significance": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "How significant this change is"
    },
    "notify_channels": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Channels to notify (ops-team, security-team, sales-team, none)"
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary of what changed and why it matters"
    },
    "action_taken": {
      "type": "string",
      "enum": ["notified", "stored", "ignored"],
      "description": "What action was taken"
    }
  },
  "required": ["table", "operation", "significance", "action_taken"]
}
