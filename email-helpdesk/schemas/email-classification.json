{
  "type": "object",
  "description": "Email classification result",
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["question", "bug_report", "feature_request", "complaint", "praise", "spam", "auto_reply"],
      "description": "Primary intent of the email"
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "department": {
      "type": "string",
      "enum": ["engineering", "billing", "sales", "hr", "legal", "general"]
    },
    "language": {
      "type": "string",
      "description": "ISO 639-1 language code (e.g. en, de, fr)"
    },
    "sender_name": {
      "type": "string",
      "description": "Extracted sender display name"
    },
    "from_address": {
      "type": "string",
      "description": "Sender email address (from from_address field) - needed for reply routing"
    },
    "original_subject": {
      "type": "string",
      "description": "Original email subject line - needed for reply subject"
    },
    "summary": {
      "type": "string",
      "description": "One-line summary of the email content"
    },
    "key_topics": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Main topics for knowledge base search"
    }
  },
  "required": ["intent", "urgency", "department", "summary", "from_address", "original_subject"]
}
