{
  "type": "object",
  "description": "Document classification and routing decision",
  "properties": {
    "category": {
      "type": "string",
      "enum": ["contract", "invoice", "report", "letter", "form", "memo", "other"]
    },
    "sub_category": {
      "type": "string",
      "description": "More specific classification (e.g. 'nda', 'sow', 'quarterly-report')"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Classification confidence; below 70 triggers human review"
    },
    "route_to": {
      "type": "string",
      "enum": ["accounts-payable", "legal-review", "analytics-team", "general-inbox", "data-entry", "manual-review"],
      "description": "Destination team or workflow"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Searchable tags for the document"
    },
    "needs_human_review": {
      "type": "boolean",
      "description": "True if confidence is low or content was truncated"
    }
  },
  "required": ["category", "confidence", "route_to"]
}
